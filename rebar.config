{erl_opts, [debug_info]}.

{deps, [
    {hb, {git, "https://github.com/permaweb/HyperBEAM.git",
        {ref, "046a1879ece05980c31190722004b0451c9512c4"}}}
]}.

{overrides, [
    {override, cowboy, [{deps, [cowlib, ranch]}]},
    {override, gun, [{deps, [cowlib]}]}
]}.

{plugins, [
    {plugin,
        {git_subdir, "https://github.com/permaweb/HyperBEAM.git",
            {ref, "046a1879ece05980c31190722004b0451c9512c4"},
            "src/forge"}},
    {rebar3_eunit_start,
        {git, "https://github.com/permaweb/rebar3_eunit_start.git",
            {ref, "04ec53fea187039770db0d4459b7aeb01a9021af"}}}
]}.

{eunit_opts, [verbose, {start_applications, [prometheus, hb]}]}.

{shell, [
    {apps, [hb]}
]}.

{alias, [
    {'eunit-all',
        [
            {device, "test --with-core"}
        ]
    }
]}.

{provider_hooks, [
    {pre, [
        {eunit, {default, rebar3_eunit_start}}
    ]}
]}.
